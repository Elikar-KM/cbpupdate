{
    "apps": [
        {
            "name": "cbp-nextjs",
            "script": "server.js",
            "cwd": "/home/cbpcommunity/nodejs/cbp-frontend",
            "instances": 2,
            "exec_mode": "cluster",
            "env": {
                "NODE_ENV": "production",
                "PORT": 3000
            },
            "error_file": "/home/cbpcommunity/nodejs/logs/nextjs-error.log",
            "out_file": "/home/cbpcommunity/nodejs/logs/nextjs-out.log",
            "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
            "merge_logs": true,
            "autorestart": true,
            "max_memory_restart": "1G",
            "watch": false,
            "ignore_watch": [
                "node_modules",
                "logs",
                ".next"
            ]
        }
    ]
}
